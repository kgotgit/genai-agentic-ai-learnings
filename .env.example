# ---------- LLM Provider Selection ----------
# Set to: groq | azure
LLM_PROVIDER=groq

# ---------- Groq (used when LLM_PROVIDER=groq) ----------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---------- Azure OpenAI (used when LLM_PROVIDER=azure) ----------
# Either AZURE_API_KEY or AZURE_OPENAI_API_KEY can be used.
AZURE_API_KEY=
# AZURE_OPENAI_API_KEY=
# Optional dedicated embedding key alias used by rag:azure
# AZURE_OPENAI_API_EMBEDDING_KEY=

# Azure deployment/model name (required for azure provider)
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2023-05-15

# Accepts endpoint forms like:
# - https://<resource>.openai.azure.com
# - https://<resource>.openai.azure.com/openai
# - https://<resource>.openai.azure.com/openai/v1
# - https://<resource>.openai.azure.com/openai/v1/chat/completions
AZURE_OPENAI_BASE_URL=https://open-ai-learn-07-05.openai.azure.com/openai/v1/chat/completions
# Optional explicit endpoint form (used by rag:azure)
# AZURE_OPENAI_ENDPOINT=https://open-ai-learn-07-05.openai.azure.com

# ---------- Retrieval / Embeddings ----------
RETRIEVAL_MODE=hybrid
EMBEDDING_MODEL=Xenova/bge-m3
FORCE_REINDEX=false

# ---------- Azure AI Search (for rag:azure) ----------
AZURE_AISEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_AISEARCH_KEY=
AZURE_AISEARCH_INDEX_NAME=practice-demo

# Optional aliases also supported by rag:azure:
# AZURE_SEARCH_ENDPOINT=
# AZURE_SEARCH_API_KEY=
# AZURE_SEARCH_INDEX_NAME=

# ---------- DialogSum Eval ----------
DIALOGSUM_CONFIG=default
DIALOGSUM_SPLIT=test
DIALOGSUM_OFFSET=0
DIALOGSUM_SAMPLE_SIZE=5
BERT_MODEL=Xenova/all-MiniLM-L6-v2
EVAL_OUTPUT_PATH=db/dialogsum-eval-results.json